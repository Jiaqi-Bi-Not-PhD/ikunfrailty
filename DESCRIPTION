Package: ikunfrailty
Title: Imputation of Covariates for Kinship-Induced Unobserved Frailty under Nonrandom Ascertainment
Version: 0.0.1
Authors@R: c(
    person("Jiaqi", "Bi", role = c("aut", "cre"), email = "jbi23@uwo.ca"),
    person("Laurent", "Briollais", role = "ctb", email = "laurent@lunenfeld.ca"),
    person("Osvaldo", "Espin-Garcia", role = "aut", email = "oespinga@uwo.ca"),
